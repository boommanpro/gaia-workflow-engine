{
  "name": "workflow-manage",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:test": "vite --mode test",
    "dev:prod": "vite --mode production",
    "build:test": "vite build --mode test",
    "build:prod": "vite build --mode production",
    "build:github": "vite build --mode github",
    "build:electron-curr": "vite build --mode electron",
    "build:electron": "cd ../workflow-editor && npm run build:electron && cd ../workflow-manage && npm run build:electron-curr && mkdir -p dist/workflow-editor && cp -r ../workflow-editor/workflow-editor/* dist/workflow-editor/",
    "preview:test": "vite preview --mode test"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.4.0",
    "element-plus": "^2.11.7",
    "marked": "^4.3.0",
    "pinia": "^2.1.0",
    "vue": "^3.3.0",
    "vue-router": "^4.2.0",
    "wujie": "^1.0.0",
    "wujie-vue3": "^1.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.2.0",
    "fs-extra": "^11.2.0",
    "vite": "^4.3.0"
  }
}
